<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_logotiponuevo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_logotiponuevo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MovilCofee"
        tools:targetApi="31">

        <!-- PANTALLA PRINCIPAL -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- GRAFICAS -->
        <activity
            android:name=".GraficasActivity"
            android:exported="false" />

        <!-- TIEMPO -->
        <activity
            android:name=".TiempoActivity"
            android:exported="false" />

        <!-- EVENTOS -->
        <activity
            android:name=".EventosActivity"
            android:exported="false" />

        <!-- AJUSTES -->
        <activity
            android:name=".AjustesActivity"
            android:exported="false" />

    </application>

</manifest>